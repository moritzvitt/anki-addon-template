{
  "title": "Global Styling",
  "ankiweb_id": null,
  "github_url": "https://github.com/moritzvitt/anki-addon-template",
  "support_url": "https://github.com/moritzvitt/anki-addon-template/issues",
  "description_source": null,
  "artifact_patterns": [
    "global-styling.ankiaddon",
    "build/*.ankiaddon"
  ],
  "build_command": [
    "bash",
    "-lc",
    "repo_name=${PWD##*/}; rm -f ./$repo_name.ankiaddon; zip -r ./$repo_name.ankiaddon . -x './.git/*' './.vscode/*' './__pycache__/*' './.DS_Store'"
  ]
}
